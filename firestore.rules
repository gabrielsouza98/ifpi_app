rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isSelf(id) { return isSignedIn() && request.auth.uid == id; }

    // Telas de login checam estes documentos
    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSelf(userId);
    }

    match /empresas/{empresaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSelf(empresaId);
    }

    // Produtos (listagem pública; escrita apenas pelo dono/empresa)
    match /produtos/{produtoId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                    request.resource.data.empresaId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                            resource.data.empresaId == request.auth.uid;
    }

    // Analytics: eventos de cliques (WhatsApp, rota, visualizações)
    match /analytics_eventos/{document} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // Tudo mais bloqueado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
